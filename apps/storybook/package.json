{
  "name": "@app/storybook",
  "version": "0.5.0",
  "description": "Storybook configuration for the web application",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf storybook-static coverage",
    "clean:all": "pnpm clean node_modules",
    "deploy": "pnpm deploy:build && pnpm deploy:move",
    "deploy:demo": "pnpm deploy:build && pnpm deploy:move",
    "deploy:build": "pnpm storybook:build",
    "deploy:move": "move-cli storybook-static \"../../output/deployment/storybook\" --mkdirp",
    "test": "vitest",
    "test:ci": "vitest --outputFile=.test-results/unit-test.xml --reporter=junit",
    "test:coverage": "vitest run --coverage --project=web-unit",
    "test:coverage:ci": "pnpm test:coverage && pnpm test:coverage:ci:move",
    "test:coverage:ci:move": "move-cli ./coverage/cobertura-coverage.xml \"../../output/coverage/web.xml\" --mkdirp",
    "test:coverage:storybook": "vitest run --coverage --project=storybook",
    "test:coverage:storybook:ci": "pnpm test:coverage:storybook && pnpm test:coverage:storybook:ci:move",
    "test:coverage:storybook:ci:move": "move-cli ./coverage/cobertura-coverage.xml \"../../output/coverage/web-storybook.xml\" --mkdirp",
    "storybook": "storybook dev -p 9080",
    "storybook:build": "storybook build -o storybook-static",
    "storybook:nopen": "pnpm storybook --no-open"
  },
  "dependencies": {
    "@app/web": "workspace:*",
    "@config/tailwind": "workspace:*",
    "@fontsource/rubik": "catalog:ui",
    "@package/ui": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-intl": "catalog:ui"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@config/vite": "workspace:*",
    "@package/storybook": "workspace:*",
    "@storybook/addon-a11y": "catalog:dev",
    "@storybook/addon-docs": "catalog:dev",
    "@storybook/addon-mcp": "catalog:dev",
    "@storybook/addon-themes": "catalog:dev",
    "@storybook/addon-vitest": "catalog:dev",
    "@storybook/builder-vite": "catalog:dev",
    "@storybook/react": "catalog:dev",
    "@storybook/react-vite": "catalog:dev",
    "@tailwindcss/vite": "catalog:dev",
    "@vitejs/plugin-react": "catalog:dev",
    "@vitest/browser": "catalog:dev",
    "@vitest/browser-playwright": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "storybook": "catalog:dev",
    "tailwindcss": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
