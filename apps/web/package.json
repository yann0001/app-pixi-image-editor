{
  "name": "@app/web",
  "version": "0.5.0",
  "description": "Pixi Image Editor built with React, TypeScript, and Vite",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "pnpm clean node_modules",
    "dev": "vite --port 5203 --open",
    "dev:e2e": "vite --port 4203 --strictPort",
    "lint": "eslint ./src",
    "lint:fix": "pnpm lint --fix",
    "generate:assets": "generate-assets public",
    "build": "pnpm generate:assets && tsc && vite build",
    "deploy": "pnpm deploy:build && pnpm deploy:move",
    "deploy:build": "pnpm build",
    "deploy:move": "move-cli dist \"../../output/deployment/app\" --mkdirp",
    "test:e2e:env": "pnpm dev:e2e",
    "test:e2e:env:coverage": "cross-env VITE_COVERAGE=true vite --port 4203 --strictPort"
  },
  "dependencies": {
    "@fontsource/rubik": "catalog:ui",
    "@heroicons/react": "catalog:ui",
    "@package/react": "workspace:*",
    "@package/storybook": "workspace:*",
    "@package/ui": "workspace:*",
    "@pixi/react": "catalog:pixi",
    "@tanstack/react-router": "catalog:tanstack",
    "clsx": "catalog:ui",
    "daisyui": "catalog:ui",
    "immer": "catalog:state",
    "jotai": "catalog:state",
    "jotai-effect": "catalog:state",
    "pixi-filters": "catalog:pixi",
    "pixi-viewport": "catalog:pixi",
    "pixi.js": "catalog:pixi",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-dropzone": "catalog:ui",
    "react-intl": "catalog:ui"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@config/vite": "workspace:*",
    "@storybook/react-vite": "catalog:dev",
    "eslint": "catalog:dev",
    "@tailwindcss/typography": "catalog:dev",
    "@tailwindcss/vite": "catalog:dev",
    "@tanstack/router-plugin": "catalog:tanstack",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-basic-ssl": "catalog:dev",
    "@vitejs/plugin-react": "catalog:dev",
    "cross-env": "catalog:dev",
    "vite-plugin-istanbul": "catalog:dev",
    "babel-plugin-react-compiler": "catalog:react",
    "move-cli": "catalog:dev",
    "rimraf": "catalog:dev",
    "storybook": "catalog:dev",
    "tailwindcss": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "@vite-pwa/assets-generator": "catalog:dev",
    "vite-plugin-pwa": "catalog:dev",
    "workbox-window": "catalog:dev"
  }
}
