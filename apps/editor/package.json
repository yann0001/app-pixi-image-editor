{
  "name": "@app/editor",
  "version": "0.1.0",
  "description": "Pixi Image Editor built with React, TypeScript, and Vite",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "pnpm clean node_modules",
    "dev": "vite --open",
    "lint": "eslint ./src",
    "lint:fix": "pnpm lint --fix",
    "build": "tsc && vite build",
    "build:demo": "tsc && vite build --mode demo",
    "deploy": "pnpm deploy:build && pnpm deploy:move",
    "deploy:build": "pnpm build",
    "deploy:demo": "pnpm deploy:demo:build && pnpm deploy:move",
    "deploy:demo:build": "pnpm build:demo",
    "deploy:move": "move-cli dist \"../../output/deployment/app\" --mkdirp"
  },
  "dependencies": {
    "@fontsource/rubik": "catalog:design",
    "@heroicons/react": "catalog:design",
    "@package/react": "workspace:*",
    "@pixi/react": "^8.0.5",
    "pixi-filters": "^6.1.5",
    "@tanstack/react-router": "catalog:tanstack",
    "clsx": "catalog:common",
    "daisyui": "^5.0.0",
    "immer": "catalog:common",
    "jotai": "catalog:common",
    "jotai-effect": "catalog:common",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.18.1",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-dropzone": "14.2.3",
    "react-intl": "catalog:common"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@config/vite": "workspace:*",
    "babel-plugin-react-compiler": "catalog:react19",
    "@tailwindcss/typography": "catalog:tailwind",
    "@tailwindcss/vite": "catalog:tailwind",
    "@tanstack/router-plugin": "catalog:tanstack",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:vite",
    "move-cli": "catalog:common",
    "rimraf": "catalog:common",
    "tailwindcss": "catalog:tailwind",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite",
    "vite-plugin-pwa": "catalog:vite",
    "workbox-window": "catalog:common"
  }
}
