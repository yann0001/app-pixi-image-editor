{
  "name": "@app/e2e",
  "version": "0.7.0",
  "description": "End-to-end tests for the web application using Playwright",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "playwright install",
    "clean": "rimraf .test-results",
    "clean:all": "pnpm clean node_modules",
    "test:e2e": "pnpm playwright test --ui --config=playwright.ui.config.ts",
    "test:e2e:ci": "cross-env PLAYWRIGHT_JUNIT_OUTPUT_NAME=\"./.test-results/results.xml\" pnpm playwright test --reporter=junit",
    "test:e2e:coverage": "cross-env COVERAGE=true PLAYWRIGHT_JUNIT_OUTPUT_NAME=\"./.test-results/results.xml\" pnpm playwright test --config=playwright.coverage.config.ts --reporter=junit",
    "test:e2e:ui": "pnpm playwright test --ui --config=playwright.ui.config.ts"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@playwright/test": "catalog:playwright",
    "cross-env": "catalog:common",
    "nyc": "catalog:coverage",
    "playwright": "catalog:playwright"
  }
}
