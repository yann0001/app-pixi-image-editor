{
  "name": "@package/react",
  "version": "0.7.0",
  "description": "Reusable best-practice hooks that complement React 19",
  "license": "MIT",
  "private": true,
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "pnpm clean node_modules",
    "lint": "eslint ./src",
    "lint:fix": "pnpm lint --fix"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@config/eslint": "workspace:*",
    "@config/typescript": "workspace:*",
    "@types/react": "catalog:react19",
    "rimraf": "catalog:common"
  }
}
