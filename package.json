{
  "name": "template-web-app-react-enterprise",
  "version": "0.5.0",
  "description": "A template for building enterprise-grade web applications using React, TypeScript, and modern tooling.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=21.0.0 <25.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "pnpm clean:root && turbo run clean",
    "clean:all": "pnpm clean:root && turbo run clean:all",
    "clean:root": "rimraf output",
    "dev": "turbo run dev",
    "dev:mocks": "turbo run dev:mocks",
    "dev:mocks:cli": "pnpm --filter=@tool/mock dev:mocks:cli",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix && sherif --fix",
    "build": "turbo run build",
    "build:libs": "turbo run build:libs",
    "deploy": "turbo run deploy",
    "storybook": "turbo run storybook",
    "storybook:build": "turbo run storybook:build",
    "storybook:nopen": "turbo run storybook:nopen",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:ci": "turbo run test:coverage:ci",
    "test:e2e": "turbo run test:e2e:env test:e2e",
    "test:e2e:ci": "turbo run test:e2e:ci",
    "test:e2e:ui": "turbo run test:e2e:env test:e2e:ui",
    "test:e2e:env": "turbo run test:e2e:env",
    "test:e2e:coverage": "turbo run test:e2e:coverage",
    "test:e2e:env:coverage": "turbo run test:e2e:env:coverage"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@types/node": "24.13.2",
    "husky": "9.1.7",
    "fast-xml-parser": "5.9.3",
    "lint-staged": "17.0.8",
    "move-cli": "catalog:dev",
    "nyc": "catalog:dev",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rimraf": "catalog:dev",
    "sherif": "1.12.0",
    "tsup": "8.5.1",
    "turbo": "2.9.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "lint-staged": {
    "*.js": "prettier --write",
    "*.ts": "prettier --write",
    "*.tsx": "prettier --write",
    "*.scss": "prettier --write"
  }
}
